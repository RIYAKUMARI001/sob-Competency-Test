{
  "name": "shopstr-mcp",
  "version": "0.1.0",
  "description": "My implementation of a Nostr NIP-99 marketplace reader for the MCP protocol.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "shopstr-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["nostr", "nip-99", "mcp", "bitcoin-marketplace", "shopstr"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "nostr-tools": "^2.7.0",
    "websocket-polyfill": "^0.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
